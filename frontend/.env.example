# ============================================================
# TaskOrbit frontend — environment template
# Copy this to `.env.local` and adjust if needed.
# `.env.local` is git-ignored. Do NOT commit it.
#
# Note: Vite only exposes variables prefixed with `VITE_` to the
# browser bundle. Anything else is silently dropped at build time.
# ============================================================

# Backend HTTP base URL (FastAPI). The dev server proxies /api/* here.
VITE_API_URL=http://localhost:8000

# LiveKit WebSocket URL — same as the backend's LIVEKIT_URL.
# Used by the frontend's LiveKit client to join rooms.
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Application name (used in window title and headings)
VITE_APP_NAME=TaskOrbit
