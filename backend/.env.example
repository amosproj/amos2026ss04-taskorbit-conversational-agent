# ============================================================
# TaskOrbit backend — environment template
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. Do NOT commit it.
# ============================================================

# --- Application ---
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
API_HOST=0.0.0.0
API_PORT=8000

# --- CORS ---
# Comma-separated list of origins allowed to talk to the FastAPI service.
# In development the Vite dev server runs on :5173.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# Database — PostgreSQL
# ------------------------------------------------------------
# The architecture document defines PostgreSQL as the persistent
# store for chat history, messages, confirmations, agent traces, and
# tool-call results.
#
# When using docker-compose, the `postgres` service in compose.yml
# matches these credentials. When running Postgres yourself, point
# this URL at your local instance.
# ============================================================
DATABASE_URL=postgresql://taskorbit:taskorbit@localhost:5432/taskorbit

# ============================================================
# LiveKit
# ------------------------------------------------------------
# For local dev you can either:
#   (a) use LiveKit Cloud (https://cloud.livekit.io) — free tier is enough
#   (b) run a local LiveKit server with `lk dev` or Docker
# Either way you'll get a URL, an API key, and a secret. The agent
# worker (downstream ticket) will use all three; the frontend only
# needs the URL.
# ============================================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ============================================================
# Speech-to-Text — Deepgram (planned per architecture doc)
# Multilingual model is required (English/German is the initial scope).
# Get a key at https://console.deepgram.com
# ============================================================
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=multi      # `multi` enables auto language detection

# ============================================================
# Text-to-Speech — ElevenLabs (planned per architecture doc)
# Get a key at https://elevenlabs.io/app/settings/api-keys
# ============================================================
ELEVENLABS_API_KEY=
# Pre-made multilingual voice (Rachel). Override per task definition if needed.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ============================================================
# LLM provider — provider TBD per architecture doc.
# Both OpenAI and Google keys can coexist; downstream code picks one.
# ============================================================
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ============================================================
# APIs — exact APIs TBD per architecture doc.
# Add credentials here once  shared.
# ============================================================
# API_BASE_URL=
# API_KEY=
